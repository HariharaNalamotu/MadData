# Zilliz Cloud (Milvus) — https://cloud.zilliz.com
CLUSTER_ENDPOINT=https://YOUR_CLUSTER_ID.api.gcp-us-west1.zillizcloud.com
TOKEN=your_zilliz_api_key_here

# HuggingFace — https://huggingface.co/settings/tokens (free account)
# Used for both Legal-BERT embeddings AND Mistral-7B chat completions
HF_TOKEN=hf_...

# Optional: swap the chat model (default: mistralai/Mistral-7B-Instruct-v0.3)
# HF_CHAT_MODEL=HuggingFaceH4/zephyr-7b-beta

# CORS — comma-separated list of allowed origins, or * for all
# In production set this to your Vercel URL, e.g.:
# ALLOWED_ORIGINS=https://chatdoc.vercel.app
ALLOWED_ORIGINS=*
